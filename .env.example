# Railway (server-side only)
ANTHROPIC_API_KEY=
# Required for the "Listen, Don't Read" briefing voice (Gemini TTS). Without it,
# the dashboard falls back to the browser's robotic SpeechSynthesis voice.
GEMINI_API_KEY=
# Optional: Gemini prebuilt TTS voice. Defaults to "Charon" (informative).
# Other natural options: Sulafat (warm), Algieba (smooth), Puck (upbeat), Kore (firm), Leda (youthful).
GEMINI_TTS_VOICE=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match Google Cloud Console OAuth redirect and your public URL, e.g.
# https://lemon.billyrovzar.com/auth/google/callback (or ceo.billyrovzar.com if DNS not migrated yet)
GOOGLE_REDIRECT_URI=https://{railway-domain}/auth/google/callback
TOKEN_ENCRYPTION_KEY=
SESSION_SECRET=
ALLOWED_EMAILS=billy@lemonfilms.com
# Required for CSRF on POST /api/* in production — must match the browser origin
ALLOWED_ORIGIN=https://{railway-domain}

# Obsidian vault (Lemon AI Center Brain + briefing rules + corrections)
# Production (Railway): set OBSIDIAN_VAULT_GIT_URL to your private vault repo; server clones to ./vault and indexes at startup.
# The vault repo is PRIVATE — the URL must embed a read-only token or the clone fails and the Brain boots empty:
#   https://x-access-token:<fine-grained PAT, Contents read-only, obsidian-brain repo only>@github.com/brovzar-lab/obsidian-brain.git
OBSIDIAN_VAULT_GIT_URL=
# Local dev: path to your vault folder if not using git clone (e.g. macOS path to OBSIDIAN BRAIN). Ignored when OBSIDIAN_VAULT_GIT_URL is set.
OBSIDIAN_VAULT_PATH=

# Firebase Admin SDK (server-side)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase Client SDK (build-time, Vite — public, non-secret)
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=

# UI feature flags
VITE_NEW_DASHBOARD=true
VITE_OPS_VIEWS=true

# --- Mission Control Engine ---
# Required: the engine runs all scheduled jobs as this Firebase uid
CEO_UID=
# C-2: Shared secret for Railway Cron HTTP triggers (POST /api/engine/cron/:jobId)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must match the ENGINE_CRON_SECRET set on each Railway Cron Service.
ENGINE_CRON_SECRET=
# Optional: enables stock quotes on the You view (free tier is plenty)
FINNHUB_API_KEY=
