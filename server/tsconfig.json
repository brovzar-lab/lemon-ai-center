{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": "..",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": "..",
    "paths": {
      "@shared/*": ["shared/*"]
    }
  },
  "include": ["../server/**/*", "../shared/**/*"],
  "exclude": [
    "node_modules",
    "../src",
    "dist",
    "../**/*.test.ts",
    "../**/*.test.tsx",
    "../**/__tests__/**"
  ]
}
