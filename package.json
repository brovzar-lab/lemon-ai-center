{
  "name": "lemon-ai-center",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"vite\" \"node --require dotenv/config ./node_modules/.bin/tsx watch server/index.ts\"",
    "build": "vite build && tsc -p server/tsconfig.json",
    "start": "node server/dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p server/tsconfig.json --noEmit"
  },
  "comments": {
    "dependencies": "Build toolchain (vite, @vitejs/plugin-react, tailwindcss, autoprefixer, postcss, typescript) and the server's @types/* live here, NOT in devDependencies. Railway/Railpack runs `npm ci` with NODE_ENV=production, which skips devDependencies — so anything `npm run build` needs MUST be a regular dependency or the build fails with 'vite: not found' (exit 127)."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@notionhq/client": "^5.20.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/flexsearch": "^0.7.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.11.5",
    "@types/node-cron": "^3.0.11",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "chokidar": "^5.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "firebase": "^12.12.1",
    "firebase-admin": "^12.0.0",
    "flexsearch": "^0.8.212",
    "googleapis": "^140.0.0",
    "gray-matter": "^4.0.3",
    "helmet": "^8.1.0",
    "lucide-react": "^1.17.0",
    "module-alias": "^2.3.4",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "zod": "^4.4.3",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/supertest": "^6.0.2",
    "agentation": "^3.0.2",
    "concurrently": "^8.2.2",
    "jsdom": "^24.0.0",
    "supertest": "^6.3.4",
    "tsx": "^4.7.0",
    "vitest": "^1.2.1"
  },
  "_moduleAliases": {
    "@shared": "server/dist/shared"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
